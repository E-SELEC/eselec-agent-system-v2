{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "ask",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*credentials*)",
      "Read(*token*)",
      "Read(*secret*)"
    ]
  }
}

