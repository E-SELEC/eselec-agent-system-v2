{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "LS"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*credentials*)",
      "Read(*token*)",
      "Read(*secret*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "python \"${CLAUDE_PROJECT_DIR}/.claude/hooks/block-sensitive-data.py\""
          }
        ]
      }
    ]
  }
}

